---
import Footer from "../components/Footer.astro";

const { title = "Swiss Ephemeris" } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <header class="header">
      <a href="/" class="brand">Swiss Ephemeris</a>
      <nav>
        <a href="/health">health</a>
        <a href="/chart">chart</a>
        <a href="/synastry">synastry</a>
        <a href="/raw">raw</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <Footer />

    <style is:global>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
        background: #0a0a1a;
        color: #e8e8f0;
        min-height: 100vh;
      }
      .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 2rem;
        border-bottom: 1px solid #1f1f33;
      }
      .brand {
        font-weight: 700;
        font-size: 1.2rem;
        background: linear-gradient(135deg, #a78bfa, #f472b6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        text-decoration: none;
      }
      nav a {
        color: #c4b5fd; text-decoration: none; margin-left: 1.5rem; font-size: 0.95rem;
      }
      main {
        max-width: 920px;
        margin: 2rem auto;
        padding: 0 2rem;
      }
      h1 {
        font-size: 2rem; margin-bottom: 0.5rem;
        background: linear-gradient(135deg, #a78bfa, #f472b6);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      table { width: 100%; border-collapse: collapse; margin-top: 1rem; }
      th, td { padding: 0.5rem 0.75rem; border-bottom: 1px solid #1f1f33; text-align: left; }
      input, select, button, textarea {
        background: #14142b; color: #e8e8f0; border: 1px solid #374151;
        padding: 0.5rem; border-radius: 4px; font-family: inherit;
      }
      button { cursor: pointer; }
      button:hover { background: #1f1f3d; }
      pre { background: #14142b; padding: 1rem; overflow: auto; border-radius: 4px; }
    </style>
  </body>
</html>
